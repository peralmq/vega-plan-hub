#!/usr/bin/env node
// The deterministic harness CLI. Contract: docs/specs/harness.spec.md.
// Zero dependencies; frontmatter is parsed by hand (flat keys + one list).

import { execSync } from "node:child_process";
import { readdirSync, readFileSync } from "node:fs";
import { basename, dirname, join } from "node:path";
import { fileURLToPath } from "node:url";

const ROOT = dirname(fileURLToPath(import.meta.url));
const PLANS_DIR = join(ROOT, "docs", "execplans");
const RECIPES_DIR = join(ROOT, "src", "data", "recipes");
const STATUSES = ["todo", "in-progress", "done", "deferred"];
const PHASE_RE = /^P\d+$/;
const ID_RE = /^p\d+-\d{2}-[a-z0-9-]+$/;
const RECIPE_ID_RE = /^[a-z0-9]+(-[a-z0-9]+)*$/;
const DIFFICULTIES = ["Easy", "Medium", "Hard"];

// Required body sections, in this order (docs/specs/harness.spec.md,
// ExecPlans). Optional sections (Decision Log, Surprises & Discoveries,
// Idempotence & Recovery) may appear anywhere after Goal.
const REQUIRED_SECTIONS = [
  "Goal",
  "Non-goals",
  "Context",
  "Progress",
  "Steps",
  "Verification",
  "Evidence",
];

const fail = (msg) => {
  console.error(`FAIL: ${msg}`);
  process.exit(1);
};

// --- frontmatter -----------------------------------------------------------

function parsePlanFile(file) {
  const text = readFileSync(file, "utf8");
  const m = text.match(/^---\n([\s\S]*?)\n---/);
  if (!m) fail(`${file}: missing frontmatter block`);
  const fm = {};
  for (const line of m[1].split("\n")) {
    if (!line.trim() || line.trim().startsWith("#")) continue;
    const kv = line.match(/^(\w[\w-]*):\s*(.*)$/);
    if (!kv) fail(`${file}: unparseable frontmatter line: ${JSON.stringify(line)}`);
    const [, key, raw] = kv;
    let value = raw.replace(/\s+#.*$/, "").trim();
    if (key === "depends_on") {
      if (!/^\[.*\]$/.test(value)) fail(`${file}: depends_on must be a [list]`);
      value = value
        .slice(1, -1)
        .split(",")
        .map((s) => s.trim().replace(/^["']|["']$/g, ""))
        .filter(Boolean);
    } else {
      value = value.replace(/^["']|["']$/g, "");
    }
    fm[key] = value;
  }
  const sections = [...text.matchAll(/^## +(.+?) *$/gm)].map((s) => s[1]);
  return { fm, sections };
}

function loadPlans() {
  let files;
  try {
    files = readdirSync(PLANS_DIR).filter((f) => f.endsWith(".md"));
  } catch {
    fail(`${PLANS_DIR} does not exist`);
  }
  return files.sort().map((f) => {
    const path = join(PLANS_DIR, f);
    return { file: path, name: basename(f, ".md"), ...parsePlanFile(path) };
  });
}

// --- plans -----------------------------------------------------------------

function validate(plans) {
  const ids = new Set(plans.map((p) => p.fm.id));
  for (const p of plans) {
    const { id, title, phase, status, depends_on } = p.fm;
    if (!id) fail(`${p.file}: missing id`);
    if (!ID_RE.test(id)) fail(`${p.file}: id ${JSON.stringify(id)} does not match ${ID_RE}`);
    if (id !== p.name) fail(`${p.file}: id "${id}" does not match filename "${p.name}"`);
    if (!title) fail(`${p.file}: missing title`);
    if (!PHASE_RE.test(phase ?? "")) fail(`${p.file}: phase must match ${PHASE_RE}, got ${JSON.stringify(phase)}`);
    if (!STATUSES.includes(status)) fail(`${p.file}: status must be one of ${STATUSES.join("|")}, got ${JSON.stringify(status)}`);
    if (!Array.isArray(depends_on)) fail(`${p.file}: missing depends_on (use [] for none)`);
    for (const dep of depends_on) {
      if (!ids.has(dep)) fail(`${p.file}: depends_on references unknown plan "${dep}"`);
    }
    const required = p.sections.filter((s) => REQUIRED_SECTIONS.includes(s));
    for (const s of REQUIRED_SECTIONS) {
      if (!required.includes(s)) fail(`${p.file}: missing required section "## ${s}"`);
    }
    if (required.join("|") !== REQUIRED_SECTIONS.join("|"))
      fail(`${p.file}: required sections out of order (want: ${REQUIRED_SECTIONS.join(", ")})`);
  }
  // cycle detection
  const byId = new Map(plans.map((p) => [p.fm.id, p]));
  const state = new Map(); // id -> "visiting" | "done"
  const visit = (id, path) => {
    if (state.get(id) === "done") return;
    if (state.get(id) === "visiting") fail(`dependency cycle: ${[...path, id].join(" -> ")}`);
    state.set(id, "visiting");
    for (const dep of byId.get(id).fm.depends_on) visit(dep, [...path, id]);
    state.set(id, "done");
  };
  for (const p of plans) visit(p.fm.id, []);
  console.log(`plans validate: OK (${plans.length} plan${plans.length === 1 ? "" : "s"})`);
}

function listPlans(plans, emptyMsg = "no plans in docs/execplans/") {
  for (const p of plans) {
    const deps = p.fm.depends_on.length ? ` deps=[${p.fm.depends_on.join(", ")}]` : "";
    console.log(`${p.fm.id}  phase=${p.fm.phase}  status=${p.fm.status}${deps}  ${p.fm.title}`);
  }
  if (!plans.length) console.log(emptyMsg);
}

function readyPlans(plans) {
  const done = new Set(plans.filter((p) => p.fm.status === "done").map((p) => p.fm.id));
  const ready = plans.filter(
    (p) => p.fm.status === "todo" && p.fm.depends_on.every((d) => done.has(d))
  );
  listPlans(ready, "no ready plans");
}

function phasePlans(plans, phase) {
  if (!PHASE_RE.test(phase ?? "")) fail(`--phase requires a phase like P0, got ${JSON.stringify(phase)}`);
  const inPhase = plans.filter((p) => p.fm.phase === phase);
  listPlans(inPhase);
  const done = inPhase.filter((p) => p.fm.status === "done").length;
  const verdict = inPhase.length === 0 ? "empty" : done === inPhase.length ? "complete" : "in progress";
  console.log(`phase ${phase}: ${verdict} (${done}/${inPhase.length} done)`);
}

// --- validate-recipe ---------------------------------------------------------
// Contract: docs/specs/recipe-format.spec.md. Mirrors the hand-rolled
// frontmatter/table/list parsing in src/services/recipeLoader.ts (same
// approach, reimplemented here since the harness can't import the app's
// TypeScript module) but fails fast and specific instead of silently
// dropping malformed data.

function parseRecipeFrontmatter(text, file) {
  const m = text.match(/^---\n([\s\S]*?)\n---\n([\s\S]*)$/);
  if (!m) fail(`${file}: missing frontmatter block (--- ... --- delimited)`);
  const [, fmText, body] = m;
  const fm = {};
  for (const line of fmText.split("\n")) {
    if (!line.trim()) continue;
    const idx = line.indexOf(":");
    if (idx === -1) fail(`${file}: unparseable frontmatter line: ${JSON.stringify(line)}`);
    const key = line.slice(0, idx).trim();
    let value = line.slice(idx + 1).trim();
    if (
      (value.startsWith('"') && value.endsWith('"')) ||
      (value.startsWith("'") && value.endsWith("'"))
    ) {
      value = value.slice(1, -1);
    }
    if (value.startsWith("[") && value.endsWith("]")) {
      fm[key] = value
        .slice(1, -1)
        .split(",")
        .map((s) => s.trim().replace(/^["']|["']$/g, ""))
        .filter(Boolean);
    } else if (value !== "" && !isNaN(Number(value))) {
      fm[key] = Number(value);
    } else {
      fm[key] = value;
    }
  }
  return { fm, body };
}

function parseRecipeIngredients(body, file) {
  const section = body.match(/## Ingredients\n\n([\s\S]*?)(?=\n## |$)/);
  if (!section) fail(`${file}: missing "## Ingredients" section`);
  const lines = section[1]
    .split("\n")
    .map((l) => l.trim())
    .filter(Boolean);
  const headerIdx = lines.findIndex((l) => l.startsWith("|"));
  if (headerIdx === -1) fail(`${file}: Ingredients section has no table`);
  const rows = [];
  for (let i = headerIdx + 2; i < lines.length; i++) {
    const row = lines[i];
    if (!row.startsWith("|")) break;
    const cols = row.split("|").map((s) => s.trim());
    if (cols.length < 6)
      fail(`${file}: ingredients table row has fewer than 5 columns: ${JSON.stringify(row)}`);
    const [, quantity, unit, key, ingredient, notes] = cols;
    if (!key) fail(`${file}: ingredients table row is missing "key": ${JSON.stringify(row)}`);
    if (!ingredient)
      fail(`${file}: ingredients table row is missing "ingredient": ${JSON.stringify(row)}`);
    rows.push({ quantity, unit, key, ingredient, notes });
  }
  if (rows.length === 0) fail(`${file}: Ingredients table has no data rows`);
  return rows;
}

function parseRecipeInstructions(body, file) {
  const section = body.match(/## Instructions\n\n([\s\S]*?)(?=\n## |$)/);
  if (!section) fail(`${file}: missing "## Instructions" section`);
  const steps = [];
  for (const line of section[1].split("\n")) {
    const m = line.trim().match(/^(\d+)\.\s*(.+)$/);
    if (m) steps.push(Number(m[1]));
  }
  if (steps.length === 0) fail(`${file}: Instructions section has no numbered steps`);
  steps.forEach((n, i) => {
    if (n !== i + 1)
      fail(`${file}: Instructions steps are not sequential from 1 (got ${steps.join(",")})`);
  });
  return steps;
}

function validateRecipeFrontmatter(fm, file, filename) {
  const id = fm.id;
  if (!id) fail(`${file}: frontmatter.id is required`);
  if (!RECIPE_ID_RE.test(id))
    fail(`${file}: frontmatter.id ${JSON.stringify(id)} must be kebab-case (${RECIPE_ID_RE})`);
  const stem = filename.replace(/\.md$/, "");
  if (id !== stem)
    fail(`${file}: frontmatter.id ${JSON.stringify(id)} must equal the filename "${stem}"`);

  if (!fm.title) fail(`${file}: frontmatter.title is required`);

  if (fm.imageUrl === undefined) fail(`${file}: frontmatter.imageUrl is required (may be "")`);
  if (typeof fm.imageUrl !== "string")
    fail(`${file}: frontmatter.imageUrl must be a string, got ${JSON.stringify(fm.imageUrl)}`);

  if (!Number.isInteger(fm.cookTime) || fm.cookTime <= 0)
    fail(`${file}: frontmatter.cookTime must be a positive integer, got ${JSON.stringify(fm.cookTime)}`);

  if (!Number.isInteger(fm.servings) || fm.servings <= 0)
    fail(`${file}: frontmatter.servings must be a positive integer, got ${JSON.stringify(fm.servings)}`);

  if (!DIFFICULTIES.includes(fm.difficulty))
    fail(
      `${file}: frontmatter.difficulty must be one of ${DIFFICULTIES.join("|")}, got ${JSON.stringify(fm.difficulty)}`,
    );

  if (!Array.isArray(fm.tags) || fm.tags.length === 0)
    fail(`${file}: frontmatter.tags must be a non-empty array, got ${JSON.stringify(fm.tags)}`);
  for (const tag of fm.tags) {
    if (!tag || typeof tag !== "string")
      fail(`${file}: frontmatter.tags contains an empty/non-string tag: ${JSON.stringify(fm.tags)}`);
  }

  return id;
}

function validateRecipeFile(path, seenIds) {
  const filename = basename(path);
  const text = readFileSync(path, "utf8");
  const { fm, body } = parseRecipeFrontmatter(text, path);
  const id = validateRecipeFrontmatter(fm, path, filename);
  if (seenIds) {
    if (seenIds.has(id)) fail(`${path}: frontmatter.id "${id}" is not unique across the corpus`);
    seenIds.add(id);
  }
  parseRecipeIngredients(body, path);
  parseRecipeInstructions(body, path);
}

function validateRecipeCommand(fileArg) {
  if (fileArg) {
    validateRecipeFile(join(ROOT, fileArg), null);
    console.log(`validate-recipe: OK (${fileArg})`);
    return;
  }
  let files;
  try {
    files = readdirSync(RECIPES_DIR).filter((f) => f.endsWith(".md") && f !== "README.md");
  } catch {
    fail(`${RECIPES_DIR} does not exist`);
  }
  const seenIds = new Set();
  for (const f of files.sort()) {
    validateRecipeFile(join(RECIPES_DIR, f), seenIds);
  }
  console.log(`validate-recipe: OK (${files.length} recipe${files.length === 1 ? "" : "s"})`);
}

// --- check -----------------------------------------------------------------

// Catches a node_modules stale relative to package.json (e.g. after a
// pull) before the build fails with an opaque rollup resolve error.
function checkDeps() {
  const pkg = JSON.parse(readFileSync(join(ROOT, "package.json"), "utf8"));
  const wanted = { ...pkg.dependencies, ...pkg.devDependencies };
  const missing = Object.keys(wanted).filter((name) => {
    try {
      readFileSync(join(ROOT, "node_modules", name, "package.json"));
      return false;
    } catch {
      return true;
    }
  });
  if (missing.length)
    fail(
      `node_modules is missing ${missing.join(", ")} — run: npm install`
    );
  console.log(`OK (${Object.keys(wanted).length} deps present)`);
}

function check() {
  process.stdout.write("check: deps ... ");
  checkDeps();
  const steps = [
    ["npm run lint", "npm run lint --silent"],
    ["npm test", "npm test --silent"],
    ["npm run build", "npm run build --silent"],
  ];
  for (const [name, cmd] of steps) {
    process.stdout.write(`check: ${name} ... `);
    try {
      execSync(cmd, { cwd: ROOT, stdio: ["ignore", "pipe", "pipe"] });
      console.log("OK");
    } catch (e) {
      console.log("FAIL");
      process.stdout.write(e.stdout?.toString() ?? "");
      process.stderr.write(e.stderr?.toString() ?? "");
      fail(`failing command: ${name}`);
    }
  }
  process.stdout.write("check: plans --validate ... ");
  validate(loadPlans());
  console.log("check: OK");
}

// --- main ------------------------------------------------------------------

const [cmd, ...args] = process.argv.slice(2);
switch (cmd) {
  case "check":
    check();
    break;
  case "test":
    try {
      execSync("npm test", { cwd: ROOT, stdio: "inherit" });
    } catch {
      fail("npm test");
    }
    break;
  case "plans": {
    const plans = loadPlans();
    if (args.includes("--validate")) validate(plans);
    else if (args.includes("--ready")) readyPlans(plans);
    else if (args.includes("--phase")) phasePlans(plans, args[args.indexOf("--phase") + 1]);
    else if (args.length) fail(`unknown plans flag: ${args.join(" ")}`);
    else listPlans(plans);
    break;
  }
  case "validate-recipe":
    validateRecipeCommand(args[0]);
    break;
  default:
    console.error(
      "usage: ./harness <check | test | plans [--validate | --ready | --phase P] | validate-recipe [file]>",
    );
    process.exit(cmd ? 1 : 0);
}
